vsphere_server   = "vcenter.example.local"
datacenter_name  = "DC1"
cluster_name     = "CLUSTER1"
datastore_name   = "DATASTORE1"
network_name     = "VM Network"
template_name    = "ubuntu-22.04-template"

vm_name          = "opencti"
num_cpus         = 4
memory           = 8192

ipv4_address     = "192.0.2.10"
ipv4_netmask     = 24
ipv4_gateway     = "192.0.2.1"
dns_server_list  = ["192.0.2.53"]

ssh_user                 = "ubuntu"
ssh_private_key_path     = "./id_rsa"   # example only, file not committed
ansible_playbook         = "./github_runner.yml"
